{
  "name": "prboom-esp32-compat",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "build": {
    "srcDir": ".",
    "includeDir": "include",
    "srcFilter": [
      "-<*>",
      "+<i_main.c>",
      "+<i_network.c>",
      "+<i_sound.c>",
      "+<i_system.c>",
      "+<i_video.c>"
    ],
    "flags": ["-Wno-implicit-function-declaration", "-Wno-unused-variable"]
  }
}
